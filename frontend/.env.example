# ─── HestIA Frontend — Environment Configuration ─────────────────────────────
#
# Copy this file to .env.local and set the backend URL:
#   cp .env.example .env.local          (Linux/macOS)
#   copy .env.example .env.local        (Windows)
#
# ─────────────────────────────────────────────────────────────────────────────

# URL of the Django backend (no trailing slash)
# Local development:
VITE_API_URL=http://localhost:8000

# If using a VS Code / GitHub Codespaces / devtunnel forwarded port, replace with your tunnel URL:
# VITE_API_URL=https://your-tunnel-subdomain.devtunnels.ms
