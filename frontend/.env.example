# ─── HestIA Frontend — Environment Configuration ─────────────────────────────
#
# Copy this file to .env.local and set the backend URL:
#   cp .env.example .env.local          (Linux/macOS)
#   copy .env.example .env.local        (Windows)
#
# ─────────────────────────────────────────────────────────────────────────────

# URL of the Django backend (no trailing slash)
# Dev tunnel backend for team testing:
VITE_API_URL=https://fjxmjtg3-8000.uks1.devtunnels.ms

# Local development fallback:
# VITE_API_URL=http://localhost:8000

# Vite HMR WebSocket host — set to the public hostname when running behind a
# reverse proxy or devtunnel so hot-reload works in the remote browser.
# Leave unset for plain localhost dev (Vite handles it automatically).
VITE_HMR_HOST=fjxmjtg3-8081.uks1.devtunnels.ms
# VITE_HMR_HOST=   # unset for local dev
