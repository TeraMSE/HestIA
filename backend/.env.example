# ─── HestIA Backend — Environment Configuration ──────────────────────────────
#
# Copy this file to .env and fill in your values:
#   cp .env.example .env          (Linux/macOS)
#   copy .env.example .env        (Windows)
#
# python-dotenv loads this automatically when Django starts.
# ─────────────────────────────────────────────────────────────────────────────

# ── Django ────────────────────────────────────────────────────────────────────
# Generate a new key with: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=change-me-generate-a-real-secret-key
DEBUG=True

# ── LLM Backend ───────────────────────────────────────────────────────────────
# Option A — Local Ollama (default, no API key needed)
#   Install: https://ollama.com   then run: ollama pull llama3.2:3b
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2:3b

# Option B — TokenFactory (ESPRIT hosted LLM, preferred if key is available)
#   Leave TOKENFACTORY_API_KEY blank to fall back to local Ollama.
TOKENFACTORY_API_KEY=
TOKENFACTORY_BASE_URL=https://tokenfactory.esprit.tn/api
TOKENFACTORY_PRIMARY_MODEL=hosted_vllm/Llama-3.1-70B-Instruct
TOKENFACTORY_FAST_MODEL=hosted_vllm/Llama-3.1-70B-Instruct
TOKENFACTORY_VERIFY_SSL=false

# Force a specific LLM backend: tokenfactory | ollama  (leave blank for auto-detect)
LLM_BACKEND=

# ── ChromaDB (social sim memory engine) ───────────────────────────────────────
CHROMA_DB_PATH=./chroma_db/memories

# ── Object Detection Backend ──────────────────────────────────────────────────
# yoloworld  — faster, works out of the box (recommended for first run)
# gdino      — more accurate, requires groundingdino-py + model weights
DETECTOR_BACKEND=yoloworld

# ── Geo / Neighborhood Intelligence ───────────────────────────────────────────
# Nominatim: identify yourself per OSM usage policy (any string works locally)
NOMINATIM_USER_AGENT=hestia/1.0

# Overpass API mirrors (comma-separated, tried in order on failure)
OVERPASS_URL=https://overpass-api.de/api/interpreter
OVERPASS_ENDPOINTS=https://overpass-api.de/api/interpreter,https://overpass.kumi.systems/api/interpreter,https://overpass.openstreetmap.fr/api/interpreter
OVERPASS_USER_AGENT=HestIA/1.0 (your-email@example.com)

# OpenRouteService — for real walking/driving travel times
#   Free key: https://openrouteservice.org/dev/#/signup
#   Leave blank to use haversine straight-line fallback estimates.
ORS_API_KEY=
ORS_BASE_URL=https://api.openrouteservice.org

# ── Runtime Caches ─────────────────────────────────────────────────────────────
NOISE_CACHE_DIR=./noise_cache
NOISE_CACHE_TTL_HOURS=24
